{
  "name": "mvbackend",
  "version": "1.0.0",
  "description": "backend MvProject",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --delay 200ms --exec \"tsx src/server.ts\"",
    "build": "tsc && resolve-tspaths",
    "start": "node dist/server.js",
    "docker": "docker-compose -f docker-compose.dev.yml --project-name dev_mvbackend up -d"
  },
  "author": "Felipe Devilla",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.17",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-pool": "^3.7.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "resolve-tspaths": "^0.8.23",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
