{
  "name": "mvbackend",
  "version": "1.0.0",
  "description": "backend MvProject",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --delay 200ms --exec \"tsx src/main.ts\"",
    "build": "tsc && resolve-tspaths",
    "start": "node dist/main.js",
    "docker": "docker-compose -f docker-compose.dev.yml --project-name dev_mvbackend up -d",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "author": "Felipe Devilla",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.17",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "file-type": "^20.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.15.6",
    "pg-pool": "^3.7.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "nodemon": "^3.1.10",
    "resolve-tspaths": "^0.8.23",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
